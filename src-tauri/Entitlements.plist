<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Applied when the release pipeline codesigns with the hardened runtime
     (required for notarization). Without audio-input, a hardened-runtime
     build cannot open the microphone at all — every voice call surface in
     the packaged app would be silently deaf regardless of TCC consent. -->
<plist version="1.0">
<dict>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
